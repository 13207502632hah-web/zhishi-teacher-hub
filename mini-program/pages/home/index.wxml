<view class="page">
  <view class="hero"><view class="eyebrow">知师研室</view><view class="title">{{me.role==='teacher'?'今日教学与批改':me.role==='parent'?'孩子的作业与订正':'我的作业与订正'}}</view><view class="muted">网站发布、提交、批改与学情使用同一套数据</view></view>
  <view wx:if="{{error}}" class="card error"><text>{{error}}</text><view class="buttonRow"><button wx:for="{{testRoles}}" wx:key="*this" size="mini" class="secondary" data-role="{{item}}" bindtap="login">测试{{item==='teacher'?'教师':item==='parent'?'家长':'学生'}}</button></view></view>
  <view wx:if="{{me && me.bindingRequired}}" class="card warning"><view class="title small">尚未完成绑定</view><view class="muted">输入邀请码后还需教师在网站确认，确认前不会显示学生数据。</view><button class="primary" bindtap="bindAccount">输入邀请码</button></view>
  <view wx:if="{{me && me.bindingStatus==='pending'}}" class="card warning"><view class="title small">绑定申请待教师确认</view><view class="muted">确认后下拉刷新即可读取对应学生数据。</view></view>
  <view wx:if="{{me && me.role==='teacher'}}" class="card"><view class="statRow"><view><b>{{counts.pendingReview||0}}</b><text>待批改</text></view><view><b>{{counts.revision||0}}</b><text>需订正</text></view></view><button class="primary" bindtap="review">进入手机快捷批改</button><view class="muted">复杂组卷、财务确认和批量维护请使用电脑网站。</view></view>
  <view wx:if="{{loading}}" class="skeleton">正在同步作业…</view>
  <view wx:if="{{!loading&&!items.length&&!error}}" class="empty">暂时没有可见作业<br/><text>下拉可重新同步</text></view>
  <view wx:for="{{items}}" wx:key="id" class="card assignmentCard" data-id="{{item.id}}" bindtap="open"><view><text class="tag">{{item.status==='published'?'进行中':'已关闭'}}</text><text wx:if="{{item.revisionCount}}" class="tag alert">需订正 {{item.revisionCount}}</text></view><view class="title small">{{item.title}}</view><view class="bodyText">{{item.requirements||'请按教师要求完成'}}</view><view class="muted">截止：{{item.dueAt||'未设置'}} · 附件 {{item.assetCount||0}}</view></view>
</view>
