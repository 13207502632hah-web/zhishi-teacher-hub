<view class="page"><view class="card"><view class="title">作业与订正</view><view class="muted">整张试卷、照片和老师反馈都在这里</view></view><view wx:if="{{error}}" class="card"><text>{{error}}</text><button class="secondary" bindtap="login">本地测试登录</button></view><view wx:if="{{!loading&&!items.length}}" class="empty">暂时没有作业</view><view wx:for="{{items}}" wx:key="id" class="card" data-id="{{item.id}}" bindtap="open"><view><text class="tag">{{item.status==='published'?'进行中':'草稿'}}</text></view><view class="title">{{item.title}}</view><view>{{item.requirements}}</view><view class="muted">截止：{{item.due_at||'未设置'}} · 附件 {{item.assetCount||0}}</view></view></view>
