<view class="page"><view class="hero"><view class="title">教师快捷批改</view><view class="muted">复杂圈画、批量维护和财务确认请使用电脑网站</view></view><view wx:if="{{error}}" class="card error">{{error}}</view><scroll-view scroll-x class="chipScroll"><button wx:for="{{assignments}}" wx:key="id" size="mini" class="chip {{assignmentId===item.id?'active':''}}" data-id="{{item.id}}" bindtap="chooseAssignment">{{item.title}} · 待批{{item.pendingReviewCount}}</button></scroll-view><view class="card" wx:if="{{assignmentId}}"><view class="title small">选择学生提交</view><button wx:for="{{submissions}}" wx:key="id" class="studentButton {{submissionId===item.id?'active':''}}" data-id="{{item.id}}" bindtap="chooseSubmission">{{item.studentName}} · {{item.status}} · 版本{{item.latestVersion||0}}</button></view><view class="card" wx:if="{{submissionId}}"><picker mode="selector" range="{{outcomes}}" range-key="label" value="{{outcomeIndex}}" bindchange="chooseOutcome"><view class="field">结果：{{outcomes[outcomeIndex].label}}</view></picker><input class="field" type="digit" value="{{score}}" data-key="score" bindinput="field" placeholder="分数（可选）"/><view class="tagGrid"><text wx:for="{{tags}}" wx:key="label" class="tag {{item.selected?'selected':''}}" data-index="{{index}}" bindtap="toggleTag">{{item.label}}</text></view><textarea class="field" value="{{note}}" data-key="note" bindinput="field" placeholder="教师评语"/><textarea class="field" value="{{requirements}}" data-key="requirements" bindinput="field" placeholder="订正要求"/><view class="buttonRow"><button class="secondary" loading="{{busy}}" bindtap="save">保存草稿</button><button class="primary" loading="{{busy}}" data-confirm="1" bindtap="save">确认并回传</button></view></view></view>
