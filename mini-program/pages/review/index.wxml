<view class="page"><view class="hero"><view class="title">教师连续批改</view><view class="muted">查看大图 → 圈画/标签/分数/评语 → 确认后自动进入下一份</view></view><view wx:if="{{error}}" class="card error">{{error}}</view><scroll-view scroll-x class="chipScroll"><button wx:for="{{assignments}}" wx:key="id" size="mini" class="chip {{assignmentId===item.id?'active':''}}" data-id="{{item.id}}" bindtap="chooseAssignment">{{item.title}} · 待批{{item.pendingReviewCount}}</button></scroll-view><view class="card" wx:if="{{assignmentId}}"><view class="title small">选择学生提交</view><button wx:for="{{submissions}}" wx:key="id" class="studentButton {{submissionId===item.id?'active':''}}" data-id="{{item.id}}" bindtap="chooseSubmission">{{item.studentName}} · {{item.status}} · 版本{{item.latestVersion||0}}</button></view><view class="card" wx:if="{{current}}"><view class="title small">{{current.studentName}}的提交</view><view class="bodyText" wx:if="{{current.textContent}}">{{current.textContent}}</view><view class="submissionImages"><view wx:for="{{current.attachments}}" wx:key="id" class="reviewImage"><image mode="aspectFill" src="{{item.localPath}}" data-index="{{index}}" bindtap="preview"/><button size="mini" class="secondary" data-index="{{index}}" bindtap="annotate">圈画批注</button></view></view><picker mode="selector" range="{{outcomes}}" range-key="label" value="{{outcomeIndex}}" bindchange="chooseOutcome"><view class="field">结果：{{outcomes[outcomeIndex].label}}</view></picker><input class="field" type="digit" value="{{score}}" data-key="score" bindinput="field" placeholder="分数（可选）"/><view class="tagGrid"><text wx:for="{{tags}}" wx:key="label" class="tag {{item.selected?'selected':''}}" data-index="{{index}}" bindtap="toggleTag">{{item.label}}</text></view><textarea class="field" value="{{note}}" data-key="note" bindinput="field" placeholder="文字评语"/><button class="secondary" bindtap="toggleRecording">{{recording?'停止并保存语音':'录制语音评语'}}</button><view class="muted">已添加批改附件 {{reviewAssets.length}} 个</view><textarea class="field" value="{{requirements}}" data-key="requirements" bindinput="field" placeholder="订正要求"/><view class="buttonRow"><button class="secondary" loading="{{busy}}" bindtap="save">保存草稿</button><button class="primary" loading="{{busy}}" data-confirm="1" bindtap="save">确认并回传 · 下一份</button></view></view></view>
