<view class="page"><view wx:if="{{loading}}" class="skeleton">正在读取作业…</view><view wx:if="{{error}}" class="card error">{{error}}<button class="secondary" bindtap="load">重试</button></view><view wx:if="{{!loading&&!error}}"><view class="hero"><view class="title">{{assignment.title||'作业详情'}}</view><view class="muted">截止：{{assignment.dueAt||'未设置'}} · {{assignment.allowParentSubmit?'允许家长代交':'仅学生本人提交'}}</view></view><view class="card"><view class="title small">完成要求</view><view class="bodyText">{{assignment.requirements||'请按教师要求完成'}}</view><view class="muted">支持多图、文字、语音、短视频、PDF 或 Word；自动预检只提示，不自动判分。</view><button wx:for="{{assignment.attachments}}" wx:key="url" class="secondary fileButton" data-url="{{item.url}}" bindtap="openFile">{{item.wholePaper?'打开整张试卷':'打开附件'}}：{{item.name}}</button></view><view wx:for="{{submissions}}" wx:key="id" class="card"><view class="title small">提交与批改</view><view class="statRow"><view><b>{{item.latestVersion||0}}</b><text>已提交版本</text></view><view><b>{{item.score===null?'—':item.score}}</b><text>教师分数</text></view></view><view wx:if="{{item.confirmedNote}}" class="notice">教师评语：{{item.confirmedNote}}</view><view wx:if="{{item.revisionRequirements}}" class="warningText">订正要求：{{item.revisionRequirements}}</view></view><button class="primary fixedAction" bindtap="submit">提交或订正</button></view></view>
