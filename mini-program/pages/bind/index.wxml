<view class="page"><view class="card"><view class="title">输入一次性邀请码</view><view class="muted">邀请码由教师在网站生成。提交后进入待确认，教师确认前不能查看学生数据。</view><input class="field codeField" type="number" maxlength="6" value="{{code}}" bindinput="input" placeholder="6位邀请码"/><button class="primary" loading="{{busy}}" disabled="{{busy||code.length!==6}}" bindtap="submit">提交绑定申请</button><view wx:if="{{message}}" class="notice">{{message}}</view></view></view>
