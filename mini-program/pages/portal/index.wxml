<view class="page"><view class="hero"><view class="title">课程、反馈与学情</view><view class="muted">只显示教师已确认、当前账号有权查看的内容</view></view><picker wx:if="{{me && me.students.length>1}}" mode="selector" range="{{me.students}}" range-key="studentName" value="{{studentIndex}}" bindchange="switchStudent"><view class="card">切换孩子：{{me.students[studentIndex].studentName}}</view></picker><view wx:if="{{loading}}" class="skeleton">正在加载…</view><view wx:if="{{error}}" class="card error">{{error}}</view><view wx:if="{{lessons.length}}" class="card"><view class="title small">近期课程</view><view wx:for="{{lessons}}" wx:key="date" class="listRow"><b>{{item.date}} {{item.startTime}}</b><text>{{item.courseName}} · {{item.location}}</text></view></view><view wx:if="{{feedback.length}}" class="card"><view class="title small">教师确认反馈</view><view wx:for="{{feedback}}" wx:key="lessonId" class="listRow"><b>{{item.date}}</b><text>{{item.content}}</text></view></view><view wx:if="{{results.length}}" class="card"><view class="title small">成绩与薄弱点</view><view wx:for="{{results}}" wx:key="title" class="listRow"><b>{{item.title}}：{{item.score}} / {{item.totalScore}}</b><text>{{item.weakKnowledge||'暂无教师确认的薄弱点'}}</text></view></view><view wx:if="{{finance.length}}" class="card"><view class="title small">课时与付款明细</view><view wx:for="{{finance}}" wx:key="date" class="listRow"><b>{{item.date}} {{item.courseName}}</b><text>本次 {{item.hours}} 课时 · 课包余 {{item.packageBalance}}</text></view></view></view>
