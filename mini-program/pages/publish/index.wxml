<view class="page"><view class="hero"><view class="eyebrow">{{step===1?'第1-2步':'第3步'}}</view><view class="title">{{step===1?'布置作业':'发布前预览'}}</view><view class="muted">对象与截止时间 → 内容与附件 → 预览发布</view></view><view wx:if="{{error}}" class="card error">{{error}}</view><view wx:if="{{step===1}}" class="card"><picker mode="selector" range="{{classes}}" range-key="name" bindchange="chooseClass"><view class="field">班级：{{className||'请选择'}}</view></picker><input class="field" value="{{title}}" data-key="title" bindinput="field" placeholder="作业标题"/><textarea class="field" value="{{requirements}}" data-key="requirements" bindinput="field" placeholder="作业内容与完成要求"/><picker mode="date" data-key="dueAt" bindchange="field"><view class="field">截止日期：{{dueAt||'未设置'}}</view></picker><view class="listRow"><text>允许家长代交</text><switch checked="{{allowParentSubmit}}" data-key="allowParentSubmit" bindchange="toggle"/></view><view class="listRow"><text>允许要求订正</text><switch checked="{{requireRevision}}" data-key="requireRevision" bindchange="toggle"/></view><button class="secondary" bindtap="addImages">添加图片附件（{{assets.length}}）</button><button class="primary" bindtap="preview">下一步：预览</button></view><view wx:else class="card"><view class="tag">{{className||'对象待确认'}}</view><view class="title small">{{title}}</view><view class="bodyText">{{requirements||'无文字要求'}}</view><view class="muted">截止：{{dueAt||'未设置'}} · 附件{{assets.length}}个 · {{allowParentSubmit?'允许家长代交':'仅学生提交'}}</view><view class="buttonRow"><button class="secondary" bindtap="back">返回修改</button><button class="secondary" loading="{{busy}}" data-status="draft" bindtap="submit">保存草稿</button><button class="primary" loading="{{busy}}" data-status="published" bindtap="submit">确认发布</button></view></view></view>
