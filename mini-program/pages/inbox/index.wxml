<view class="page"><view class="hero"><view class="title">作业收件箱</view><view class="muted">未交、已交待批、需订正、已完成统一查看</view></view><view wx:if="{{error}}" class="card error">{{error}}</view><scroll-view scroll-x class="chipScroll"><button wx:for="{{assignments}}" wx:key="id" size="mini" class="chip {{assignmentId===item.id?'active':''}}" data-id="{{item.id}}" bindtap="chooseAssignment">{{item.title}}</button></scroll-view><view class="buttonRow"><button wx:for="{{tabs}}" wx:key="key" size="mini" class="{{tab===item.key?'primary':'secondary'}}" data-key="{{item.key}}" bindtap="chooseTab">{{item.label}}</button></view><view class="card" wx:for="{{submissions}}" wx:key="id" wx:if="{{(tab==='pending'&&item.status==='pending')||(tab==='submitted'&&(item.status==='submitted'||item.status==='revision_submitted'))||(tab==='revision'&&item.status==='revision')||(tab==='completed'&&(item.status==='completed'||item.status==='excellent'))}}" data-id="{{item.id}}" bindtap="review"><view class="title small">{{item.studentName}}</view><view class="muted">状态：{{item.status}} · 版本{{item.latestVersion||0}} · {{item.submittedAt||'尚未提交'}}</view></view><view wx:if="{{!loading&&!submissions.length}}" class="empty">当前作业暂无学生记录</view></view>
