{
  "name": "site-creator-vinext-starter",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "prepare:ocr": "node scripts/prepare-ocr-assets.mjs",
    "predev": "node scripts/prepare-ocr-assets.mjs",
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "prebuild": "node scripts/prepare-ocr-assets.mjs",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "node scripts/prepare-ocr-assets.mjs && WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build && node --test tests/*.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern .artifacts --ignore-pattern public/ocr",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "mini:prepare": "node scripts/mini-automation.mjs prepare",
    "mini:dev": "node scripts/mini-automation.mjs dev",
    "mini:check": "node scripts/mini-automation.mjs check",
    "mini:e2e": "node scripts/mini-automation.mjs e2e",
    "mini:verify": "node scripts/mini-automation.mjs verify",
    "mini:preview": "node scripts/mini-automation.mjs preview",
    "teaching:e2e": "node scripts/teaching-loop-e2e.mjs"
  },
  "dependencies": {
    "@tesseract.js-data/chi_sim": "1.0.0",
    "docx": "^9.7.1",
    "drizzle-orm": "0.45.2",
    "exceljs": "4.4.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "mammoth": "^1.12.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tesseract.js": "^7.0.0",
    "tesseract.js-core": "7.0.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "miniprogram-automator": "0.12.1",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
